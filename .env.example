# 复制为 .env 并填入真实值（.env 不要提交到 git）

# GitHub Personal Access Token（用于定时任务推送数据）
# 创建地址：https://github.com/settings/tokens/new
# 权限勾选：repo（Full control of private repositories）
GITHUB_TOKEN=your_github_token_here

# GitHub 仓库名（格式：用户名/仓库名）
GITHUB_REPO=lipeng01/stock-dashboard

# Git 默认分支
GIT_BRANCH=main
